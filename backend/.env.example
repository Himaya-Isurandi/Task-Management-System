PORT=5000
NODE_ENV=development
APP_NAME=TaskNova

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace_with_smtp_username
SMTP_PASS=replace_with_smtp_password
SMTP_FROM=no-reply@tasknova.com

# Backward-compatible aliases used by older local configs.
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=replace_with_smtp_username
EMAIL_PASS=replace_with_smtp_password
EMAIL_FROM=no-reply@tasknova.com
